# ============================================================
# QA Automation Template — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# Environment
# ------------------------------------------------------------
# Options: staging | uat | production
ENVIRONMENT=staging

# ------------------------------------------------------------
# App URLs
# ------------------------------------------------------------
# Base URL of the web app (no trailing slash)
BASE_URL=https://staging.yourapp.com

# Base URL for API tests (no trailing slash)
API_BASE_URL=https://staging.yourapp.com/api/v1

# ------------------------------------------------------------
# Test Credentials
# Use dedicated test accounts — never real user accounts
# ------------------------------------------------------------
TEST_USER_EMAIL=qa-test@yourapp.com
TEST_USER_PASSWORD=your-test-password

# Admin account (if app has admin role)
TEST_ADMIN_EMAIL=qa-admin@yourapp.com
TEST_ADMIN_PASSWORD=your-admin-password

# API auth token (bearer token for API tests)
# Leave blank if API uses session/cookie auth tested via browser
API_AUTH_TOKEN=

# ------------------------------------------------------------
# CE Express API test codes (for tests/api/ce-express-api.spec.js)
# ------------------------------------------------------------
# A real in-transit tracking code for API tests
CE_VALID_TRACKING_CODE=

# A tracking code currently in Out for Delivery status (optional)
CE_OFD_TRACKING_CODE=

# ------------------------------------------------------------
# Bot automation (for tests/bot/ — mock-based tests)
# ------------------------------------------------------------
# The webhook URL of the bot in staging (where tests will POST fake updates)
BOT_WEBHOOK_URL=http://localhost:8080/webhook

# Port for the mock Telegram API server (npm run mock)
MOCK_PORT=4444

# Fake chat ID used in automated bot tests (any number)
TEST_CHAT_ID=999999999

# ------------------------------------------------------------
# Asana Integration
# Auto-creates bug tasks when tests fail
# ------------------------------------------------------------
# Personal access token from: Asana > Profile > Apps > Personal Access Tokens
ASANA_TOKEN=

# Project GID — found in the Asana project URL:
# app.asana.com/0/[PROJECT_GID]/list
ASANA_PROJECT_ID=

# Assignee GID — Asana user ID to assign bug tasks to (optional)
# Leave blank to create unassigned tasks
ASANA_ASSIGNEE_GID=

# ------------------------------------------------------------
# Test Behavior
# ------------------------------------------------------------
# How long to wait for elements/responses (milliseconds)
DEFAULT_TIMEOUT=30000

# How many times to retry a failed test before marking it failed
RETRY_COUNT=1

# Run tests in headed mode by default? true | false
# (Override with --headed flag in CLI)
HEADED=false
