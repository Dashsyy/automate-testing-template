{
  "name": "qa-automation-template",
  "version": "1.0.0",
  "description": "QA automation template for E2E and API testing with Playwright and Asana integration",
  "type": "module",
  "scripts": {
    "portal": "node portal/server.js",
    "mock": "node mock/telegram-mock.js",
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e/",
    "test:api": "playwright test tests/api/",
    "test:bot": "playwright test tests/bot/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report reports/html"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  }
}
